{
  "name": "bilibili-bot-sdk",
  "version": "1.0.0",
  "description": "Standalone TypeScript SDK for the Bilibili private IM bot API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.13.4",
    "@grpc/proto-loader": "^0.7.0",
    "axios": "^1.7.7",
    "form-data": "^4.0.1",
    "image-size": "^1.2.0",
    "p-queue": "^7.3.0",
    "protobufjs": "^7.4.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
